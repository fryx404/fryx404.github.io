---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import "../styles/post.css";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";

type NavItem = { title: string; slug: string };
type Props = CollectionEntry<"works">["data"] & {
    prev?: NavItem | null;
    next?: NavItem | null;
};

const { title, pubDate, image, description, tags, url, prev, next } = Astro.props;
---

<html lang="ja">
    <head>
        <BaseHead
            title={`${title} — WORKS`}
            description={description ?? title}
        />
        <style>
            .external-link {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                margin-top: 2.5rem;
                padding: 0.8rem 1.6rem;
                font-size: 1.1rem;
                font-weight: 700;
                border-radius: 999px;
                background: color-mix(in srgb, #4c6ef5 15%, #ffffff);
                color: #364fc7;
                border: 1px solid rgba(255, 255, 255, 0.5);
                box-shadow:
                    0 4px 6px -1px rgb(0 0 0 / 0.1),
                    0 2px 4px -2px rgb(0 0 0 / 0.1),
                    inset 0 2px 0 rgba(255, 255, 255, 0.7);
                text-decoration: none;
                transition:
                    transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1),
                    box-shadow 0.2s ease;
                transform: rotate(-1.5deg);
            }
            .external-link:hover {
                transform: translateY(-4px) rotate(0deg) scale(1.05);
                box-shadow:
                    0 10px 15px -3px rgb(0 0 0 / 0.15),
                    0 4px 6px -4px rgb(0 0 0 / 0.1),
                    inset 0 2px 0 rgba(255, 255, 255, 0.8);
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <article>
                {
                    image && (
                        <div class="hero-image">
                            {image.format === "gif" ? (
                                <img
                                    src={image.src}
                                    alt={title}
                                    style="width: 100%; max-height: 480px; object-fit: cover; border-radius: 12px; box-shadow: var(--box-shadow); display: block; margin: 0 auto;"
                                />
                            ) : (
                                <Image src={image} alt={title} width={1020} />
                            )}
                        </div>
                    )
                }
                <div class="prose">
                    <div class="header-block">
                        <h1
                            class="section-title-tag"
                            style="--tag-bg: #845ef7;"
                        >
                            {title}
                        </h1>
                        <p class="meta"><FormattedDate date={pubDate} /></p>
                        {
                            tags && tags.length > 0 && (
                                <ul class="feature-tags">
                                    {tags.map((tag: string) => (
                                        <li class="feature-tag">{tag}</li>
                                    ))}
                                </ul>
                            )
                        }
                        {
                            url && (
                                <a
                                    class="external-link"
                                    href={url}
                                    target="_blank"
                                    rel="noopener"
                                >
                                    プロジェクトを見る →
                                </a>
                            )
                        }
                    </div>
                    <hr />
                    <slot />
                </div>
            </article>
            {(prev || next) && (
                <nav class="post-nav">
                    {next ? (
                        <a class="post-nav-link prev" href={`/works/${next.slug}`}>
                            <span class="nav-direction">← 次の投稿</span>
                            <span class="nav-title">{next.title}</span>
                        </a>
                    ) : <div class="post-nav-placeholder" />}
                    {prev ? (
                        <a class="post-nav-link next" href={`/works/${prev.slug}`}>
                            <span class="nav-direction">前の投稿 →</span>
                            <span class="nav-title">{prev.title}</span>
                        </a>
                    ) : <div class="post-nav-placeholder" />}
                </nav>
            )}
            <div class="back-link-wrapper">
                <a class="back-link" href="/works">
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        style="margin-right: 0.5rem;"
                        ><line x1="19" y1="12" x2="5" y2="12"></line><polyline
                            points="12 19 5 12 12 5"></polyline></svg
                    >
                    WORKS 一覧に戻る
                </a>
            </div>
        </main>
        <Footer />
        <script>
            import { applyRandomTagColors } from "../utils/tagColors";

            if (document.readyState === "loading") {
                document.addEventListener("DOMContentLoaded", () =>
                    applyRandomTagColors(".feature-tag"),
                );
            } else {
                applyRandomTagColors(".feature-tag");
            }
        </script>
    </body>
</html>
