---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import SocialIcon from "../components/SocialIcon.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- ヒーローセクション：プロフィール画像と名前 -->
			<section class="hero">
				<div class="avatar">
					<img src="/icons/Profile.png" alt="Profile" />
				</div>
				<h1 class="hero-name">古屋 匠</h1>
				<div class="hero-badges">
					<span class="feature-tag">CG Designer</span>
					<span class="feature-tag">Rigger</span>
					<span class="feature-tag">Creator</span>
				</div>
			</section>

			<!-- できることセクション -->
			<div class="features-section">
				<div class="features-wrapper">
					<div class="section-title-tag">できること</div>
					<div class="feature-cards-wrap">
						<div class="feature-card">
							<h3 class="feature-title">CGが作れる</h3>
							<p>
								MayaやBlender等を用いて、モデリングからテクスチャリング、ライティングまで一貫したCG制作を行うことができます。
							</p>
							<div class="feature-tags">
								<span class="feature-tag">Maya</span>
								<span class="feature-tag">Blender</span>
								<span class="feature-tag">Unreal Engine</span>
								<span class="feature-tag">AfterEffects</span>
								<span class="feature-tag">Photoshop</span>
							</div>
						</div>

						<div class="feature-card">
							<h3 class="feature-title">リグが組める</h3>
							<p>
								キャラクターやプロップに対し、アニメーターが直感的で動かしやすいよう、骨組みやコントローラーを設定する高度なセットアップが可能です。
							</p>
							<div class="feature-tags">
								<span class="feature-tag">Maya</span>
								<span class="feature-tag">Unreal Engine</span>
								<span class="feature-tag">MEL</span>
								<span class="feature-tag">Python</span>
							</div>
						</div>

						<div class="feature-card">
							<h3 class="feature-title">ツールが作れる</h3>
							<p>
								PythonやJavaScript等を用いて、DCCツールのプラグイン開発や、業務効率化のためのスクリプト・ツールを構築できます。
							</p>
							<div class="feature-tags">
								<span class="feature-tag">Python</span>
								<span class="feature-tag">JavaScript</span>
								<span class="feature-tag">TypeScript</span>
								<span class="feature-tag">HTML CSS</span>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- すきなことセクション -->
			<div class="likes-section">
				<div class="section-title-tag">すきなもの</div>
				<div class="likes-wrapper">
					<span class="like-sticker">PKM</span>
					<span class="like-sticker">AIとの会話</span>
					<span class="like-sticker">写真</span>
					<span class="like-sticker">ゲーム</span>
					<span class="like-sticker">手帳</span>
					<span class="like-sticker">植物</span>
					<span class="like-sticker">猫</span>
					<span class="like-sticker">コーヒー</span>
					<span class="like-sticker">記録すること</span>
				</div>
			</div>

			<!-- 外部サービスへのソーシャルリンク一覧 -->
			<div class="connect-section">
				<div class="section-title-tag">SNS</div>
				<div class="social-links-row">
					<!-- note -->
					<a
						href="https://note.com/fryx404"
						target="_blank"
						aria-label="note"
					>
						<SocialIcon name="note" />
					</a>
					<!-- X -->
					<a
						href="https://x.com/fryx404"
						target="_blank"
						aria-label="X (Twitter)"
					>
						<SocialIcon name="x" />
					</a>

					<!-- LinkedIn -->
					<a
						href="https://www.linkedin.com/in/fryx404/"
						target="_blank"
						aria-label="LinkedIn"
					>
						<SocialIcon name="linkedin" />
					</a>
					<!-- GitHub -->
					<a
						href="https://github.com/fryx404"
						target="_blank"
						aria-label="GitHub"
					>
						<SocialIcon name="github" />
					</a>
					<!-- Behance -->
					<a
						href="https://www.behance.net/fryx404/"
						target="_blank"
						aria-label="Behance"
					>
						<SocialIcon name="behance" />
					</a>
					<!-- ArtStation -->
					<a
						href="https://www.artstation.com/fryx404"
						target="_blank"
						aria-label="ArtStation"
					>
						<SocialIcon name="artstation" />
					</a>
					<!-- Contact -->
					<a
						href="https://fryx404.notion.site/13259fe4f8ee80f0826ed878a6fa6a42"
						target="_blank"
						aria-label="Contact"
					>
						<SocialIcon name="mail" />
					</a>
				</div>
			</div>
		</main>

		<Footer />
		<style>
			/* --- ページ全体の大枠レイアウト --- */
			main {
				width: 100%;
				padding: 2rem 0 0;
			}
			/* --- ヒーローセクション（プロフィール） --- */
			.hero {
				max-width: 720px;
				margin: 0 auto 0rem;
				text-align: center;
				display: flex;
				flex-direction: column;
				align-items: center;
			}
			.avatar {
				margin-bottom: 1.5rem;
				display: flex;
				justify-content: center;
			}
			.avatar img {
				width: 140px;
				height: 140px;
				border-radius: 50%;
				object-fit: cover;
				/* ステッカー風の太枠と影 */
				border: 6px solid #ffffff;
				box-shadow:
					0 12px 20px -8px rgb(0 0 0 / 0.15),
					0 4px 6px -2px rgb(0 0 0 / 0.1);
			}
			.hero-name {
				font-size: 2.2rem;
				font-weight: 800;
				color: var(--black);
				margin: 0 0 1.2rem 0;
				position: relative;
				display: inline-block;
				/* マーカー風の黄色いアンダーライン */
				background: linear-gradient(
					transparent 65%,
					rgba(255, 213, 79, 0.8) 65%
				);
				padding: 0 0.5rem;
			}
			.hero-badges {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6rem;
				justify-content: center;
			}
			/* 各セクションごとにベースの色と傾きを変更 */
			.features-section .section-title-tag {
				--tag-bg: #ffca28; /* イエロー */
				transform: rotate(-3deg);
			}
			.likes-section .section-title-tag {
				--tag-bg: #42dfb2; /* ミント */
				transform: rotate(1.5deg);
			}
			.connect-section .section-title-tag {
				--tag-bg: #4c6ef5; /* ブルー/インディゴ */
				transform: rotate(-1.5deg);
			}

			/* --- できることセクション --- */
			.features-section {
				width: 100%;
				padding: 0 0 2rem;
			}
			.features-wrapper {
				max-width: 800px;
				margin: 0 auto;
				padding: 3rem 1.5rem;
			}
			.feature-cards-wrap {
				display: flex;
				flex-direction: column;
				gap: 4rem; /* カードとカードの間隔 */
				margin-bottom: -2rem;
			}
			.feature-card {
				position: relative;
				border-radius: 16px;
				padding: 2.5rem 3rem;
				transition: transform 0.2s ease;
			}
			.feature-card:hover {
				transform: translateY(-2px);
			}
			.feature-card:nth-of-type(1) {
				background-color: color-mix(in srgb, var(--accent) 6%, #ffffff);
			}
			.feature-card:nth-of-type(2) {
				background-color: color-mix(
					in srgb,
					var(--accent-dark) 6%,
					#ffffff
				);
			}
			.feature-card:nth-of-type(3) {
				background-color: color-mix(in srgb, #ff9d00 6%, #ffffff);
			}

			/* --- 見出しのしおり・リボン装飾 --- */
			.feature-title {
				position: relative;
				display: flex;
				align-items: center;
				color: var(--black);
				font-size: 1.4rem;
				margin: 0 0 1rem 0;
				/* 左側に装飾用のスペースを空ける */
				padding-left: 2rem;
			}
			/* 各見出しに共通の「しおり・リボン（下に切り込み）」型擬似要素 */
			.feature-title::before {
				content: "";
				position: absolute;
				left: 4px; /* 横位置微調整 */
				top: -0.2em; /* 文字より少し上に突き出させる */
				width: 14px;
				height: 1.4em;
				clip-path: polygon(
					0 0,
					100% 0,
					100% 100%,
					50% calc(100% - 4px),
					0 100%
				);
			}

			/* 各カードの色に合わせてしおりの色を変更 */
			.feature-card:nth-of-type(1) .feature-title::before {
				background-color: var(--accent);
			}
			.feature-card:nth-of-type(2) .feature-title::before {
				background-color: var(--accent-dark);
			}
			.feature-card:nth-of-type(3) .feature-title::before {
				background-color: #ff9d00;
			}

			.feature-card p {
				color: var(--gray-dark);
				font-size: 1rem;
				line-height: 1.8;
				margin: 0;
				/* 見出しの装飾（padding-left: 2rem）に開始位置を合わせる */
				padding-left: 2rem;
			}
			.feature-tags {
				display: flex;
				flex-wrap: wrap;
				justify-content: flex-end;
				gap: 0.5rem;
				margin-top: 1.5rem;
				margin-right: -3.5rem; /* カードのpadding 3rem + はみ出し 0.5rem */
				margin-bottom: -3.3rem; /* カードのpadding 2.5rem + はみ出し 0.8rem */
				z-index: 10;
			}
			.feature-tag {
				position: relative;
				color: var(--gray-dark);
				padding: 0.35rem 0.8rem 0.35rem 1.6rem;
				border-radius: 0 4px 4px 0;
				font-size: 1rem;
				font-weight: 700;
				filter: drop-shadow(0 3px 6px rgb(0 0 0 / 0.15));
				clip-path: polygon(12px 0, 100% 0, 100% 100%, 12px 100%, 0 50%);
				transition: transform 0.2s ease;
				/* JS側でランダムな角度が設定されるための変数。初期値は0度 */
				transform: rotate(var(--tag-rotation, 0deg));
			}

			.feature-tag:hover {
				transform: translateY(-2px) rotate(0deg) scale(1.05);
				z-index: 11;
			}
			.feature-tag::before {
				content: "";
				position: absolute;
				top: 50%;
				left: 6px;
				width: 5px;
				height: 5px;
				background-color: rgb(0 0 0 / 0.15);
				border-radius: 50%;
				transform: translateY(-50%);
				box-shadow: inset 0 1px 2px rgb(0 0 0 / 0.2);
			}
			@media (max-width: 720px) {
				.feature-card {
					padding: 1.8rem 1.5rem 2.5rem; /* モバイル向けに下部の余白を確保 */
				}
				.feature-tags {
					margin-right: -2rem; /* モバイルpadding 1.5rem + はみ出し 0.5rem */
					margin-bottom: -3.3rem;
				}
			}

			/* --- すきなことセクション（フローティングステッカー） --- */
			.likes-section {
				max-width: 800px;
				margin: 4rem auto 6rem;
				padding: 0 1.5rem;
				text-align: center;
			}
			.likes-wrapper {
				display: flex;
				flex-wrap: wrap;
				gap: 1.5rem;
				justify-content: center;
				margin-top: 2rem;
			}
			.like-sticker {
				position: relative;
				display: inline-flex;
				align-items: center;
				padding: 0.5rem 1rem 0.5rem 1.8rem;
				font-size: 1.1rem;
				font-weight: 700;
				border-radius: 0 4px 4px 0;
				clip-path: polygon(12px 0, 100% 0, 100% 100%, 12px 100%, 0 50%);
				filter: drop-shadow(0 3px 6px rgb(0 0 0 / 0.15));
				color: var(--gray-dark);
				cursor: default;
				transition: transform 0.2s ease;
				transform: rotate(var(--tag-rotation, 0deg));
			}
			.like-sticker::before {
				content: "";
				position: absolute;
				top: 50%;
				left: 6px;
				width: 5px;
				height: 5px;
				background-color: rgb(0 0 0 / 0.15);
				border-radius: 50%;
				transform: translateY(-50%);
				box-shadow: inset 0 1px 2px rgb(0 0 0 / 0.2);
			}

			/* ステッカーの色はJSでランダムに割り当てる */

			.like-sticker:hover {
				transform: translateY(-2px) rotate(0deg) scale(1.05);
				filter: drop-shadow(0 8px 15px rgb(0 0 0 / 0.2));
				z-index: 10;
			}

			/* --- ソーシャルリンクエリア --- */
			.connect-section {
				max-width: 720px;
				margin: 4rem auto 6rem;
				padding: 0 1em;
				text-align: center;
			}
			.social-links-row {
				display: flex;
				gap: 1.2rem;
				justify-content: center;
				flex-wrap: wrap;
			}
			.social-links-row svg {
				width: 28px;
				height: 28px;
			}
			.social-links-row a {
				display: flex;
				align-items: center;
				justify-content: center;
				width: 72px;
				height: 72px;
				background: var(--gray-light);
				color: var(--gray-dark);
				border-radius: 16px;
				border: 1px solid var(--gray);
				box-shadow:
					0 4px 6px -1px rgb(0 0 0 / 0.05),
					0 2px 4px -2px rgb(0 0 0 / 0.05);
				transition: all 0.2s ease;
				text-decoration: none;
			}
			/* ソーシャルアイコンの大げさなホバーアニメーション */
			.social-links-row a:hover {
				box-shadow:
					0 20px 25px -5px rgb(0 0 0 / 0.15),
					0 8px 10px -6px rgb(0 0 0 / 0.1);
				color: #ffffff;
			}
			/* アイコンごとにタグと同じようにカラフルなホバー色と、少し傾くアニメーションを設定 */
			.social-links-row a:nth-child(1):hover {
				background-color: #ff4b4b;
				border-color: #ff4b4b;
				transform: translateY(-6px) scale(1.15) rotate(-6deg);
			}
			.social-links-row a:nth-child(2):hover {
				background-color: #22b8cf;
				border-color: #22b8cf;
				transform: translateY(-6px) scale(1.15) rotate(6deg);
			}
			.social-links-row a:nth-child(3):hover {
				background-color: #845ef7;
				border-color: #845ef7;
				transform: translateY(-6px) scale(1.15) rotate(-4deg);
			}
			.social-links-row a:nth-child(4):hover {
				background-color: #ff922b;
				border-color: #ff922b;
				transform: translateY(-6px) scale(1.15) rotate(5deg);
			}
			.social-links-row a:nth-child(5):hover {
				background-color: #94d82d;
				border-color: #94d82d;
				transform: translateY(-6px) scale(1.15) rotate(-5deg);
			}
			.social-links-row a:nth-child(6):hover {
				background-color: #f06595;
				border-color: #f06595;
				transform: translateY(-6px) scale(1.15) rotate(4deg);
			}
			.social-links-row a:nth-child(7):hover {
				background-color: #4c6ef5;
				border-color: #4c6ef5;
				transform: translateY(-6px) scale(1.15) rotate(-6deg);
			}
		</style>
		<script>
			import { TAG_COLORS, applyRandomTagColors } from "../utils/tagColors";

			document.addEventListener("DOMContentLoaded", () => {
				// できることカードのタグ：カード背景色と近い色を除外
				const excludeByIndex: Record<number, string[]> = {
					0: ["blue"],
					1: ["pink", "red"],
					2: ["orange"],
					3: ["green"],
				};
				document.querySelectorAll(".feature-card").forEach((card, index) => {
					const exclude = excludeByIndex[index] ?? [];
					const available = TAG_COLORS.filter((c) => !exclude.includes(c.name));
					applyRandomTagColors(".feature-tag", available, card);
				});

				// ヒーローバッジ・すきなことステッカー
				applyRandomTagColors(".hero-badges .feature-tag");
				applyRandomTagColors(".like-sticker");
			});
		</script>
	</body>
</html>
