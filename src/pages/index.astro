---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import HomeHero from "../components/HomeHero.astro";
import HomeFeatures from "../components/HomeFeatures.astro";
import HomeLikes from "../components/HomeLikes.astro";
import SocialLinks from "../components/SocialLinks.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <HomeHero />
      <HomeFeatures />
      <HomeLikes />
      <SocialLinks />
    </main>

    <Footer />
    
    <style>
      /* --- ページ全体の大枠レイアウト --- */
      main {
        width: 100%;
        padding: 2rem 0 0;
      }
    </style>
    
    <script>
      import { TAG_COLORS, applyRandomTagColors } from "../utils/tagColors";

      document.addEventListener("DOMContentLoaded", () => {
        // できることカードのタグ：カード背景色と近い色を除外
        const excludeByIndex: Record<number, string[]> = {
          0: ["blue"],
          1: ["pink", "red"],
          2: ["orange"],
          3: ["green"],
        };
        document.querySelectorAll(".feature-card").forEach((card, index) => {
          const exclude = excludeByIndex[index] ?? [];
          const available = TAG_COLORS.filter((c) => !exclude.includes(c.name));
          applyRandomTagColors(".feature-tag", available, card);
        });

        // ヒーローバッジ・すきなことステッカー
        applyRandomTagColors(".hero-badges .feature-tag");
        applyRandomTagColors(".like-sticker");
      });
    </script>
  </body>
</html>
