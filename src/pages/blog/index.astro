---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import { idToSlug } from "../../utils/slug";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const cardColors = [
	"#22b8cf",
	"#845ef7",
	"#ff922b",
	"#94d82d",
	"#f06595",
	"#ff4b4b",
];
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead
			title={`BLOG — ${SITE_TITLE}`}
			description={SITE_DESCRIPTION}
		/>
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 3em 1em;
			}
			.blog-page-title {
				--tag-bg: #22b8cf;
				transform: rotate(-1.5deg);
			}
			.blog-description {
				display: flex;
				justify-content: center;
				width: fit-content;
				text-align: center;
				color: var(--gray-dark);
				font-size: 1.05rem;
				font-weight: 700;
				margin: 2.5rem auto 4rem;
				padding: 0.8rem 1.8rem;
				background: #ffffff;
				border: 1px solid rgba(255, 255, 255, 0.8);
				border-radius: 999px;
				box-shadow:
					0 4px 6px -1px rgb(0 0 0 / 0.1),
					0 2px 4px -2px rgb(0 0 0 / 0.1),
					inset 0 2px 0 rgba(255, 255, 255, 0.7);
				transform: rotate(1.5deg);
			}
			.works-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 2.5rem;
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.works-card {
				position: relative;
				border-radius: 16px;
				transition:
					box-shadow 0.2s,
					transform 0.2s;
				display: flex;
				flex-direction: column;
				overflow: visible;
			}
			.works-card > .card-tags {
				position: absolute;
				top: 0.8rem;
				left: -0.5rem;
				display: flex;
				flex-wrap: wrap;
				justify-content: flex-start;
				gap: 0.5rem;
				list-style: none;
				padding: 0;
				margin: 0;
				z-index: 10;
			}
			.works-card:hover {
				box-shadow: 0 10px 20px -5px rgb(0 0 0 / 0.1);
				transform: translateY(-3px);
			}
			.works-card a {
				text-decoration: none;
				color: inherit;
				display: flex;
				flex-direction: column;
				height: 100%;
				border-radius: 16px;
			}
			.card-image-wrapper {
				position: relative;
				width: 100%;
				aspect-ratio: 16 / 9;
				border-radius: 16px 16px 0 0;
				overflow: hidden;
			}
			.card-image {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}
			.card-image-placeholder {
				width: 100%;
				height: 100%;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 2.5rem;
				background: linear-gradient(
					135deg,
					color-mix(in srgb, var(--theme-color) 15%, #ffffff),
					color-mix(in srgb, var(--theme-color) 30%, #ffffff)
				);
			}

			.works-tag-item {
				position: relative;
				color: var(--gray-dark);
				padding: 0.25rem 0.6rem 0.25rem 1.4rem;
				display: inline-block;
				font-size: 0.85rem;
				font-weight: 700;
				filter: drop-shadow(0 3px 6px rgb(0 0 0 / 0.15));
				clip-path: polygon(10px 0, 100% 0, 100% 100%, 10px 100%, 0 50%);
				transition: transform 0.2s ease;
				transform: rotate(var(--tag-rotation, 0deg));
			}
			.works-tag-item:hover {
				transform: translateY(-2px) rotate(0deg) scale(1.05);
				z-index: 11;
			}
			.works-tag-item::before {
				content: "";
				position: absolute;
				top: 50%;
				left: 4px;
				width: 4px;
				height: 4px;
				background-color: rgb(0 0 0 / 0.15);
				border-radius: 50%;
				transform: translateY(-50%);
				box-shadow: inset 0 1px 2px rgb(0 0 0 / 0.2);
			}
			.card-body {
				padding: 1rem;
				flex: 1;
				border-radius: 0 0 16px 16px;
				background-color: color-mix(in srgb, var(--theme-color) 6%, #ffffff);
			}
			.card-title {
				margin: 0 0 0.4rem;
				font-size: 1.1rem;
				color: rgb(var(--black));
			}
			.card-date {
				margin: 0;
				font-size: 0.8rem;
				color: rgb(var(--gray));
			}
			@media (max-width: 720px) {
				.works-grid {
					gap: 3rem;
				}
			}
			.empty {
				color: var(--gray-dark);
				text-align: center;
				padding: 4rem 0;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1
				class="section-title-tag blog-page-title"
				style="--tag-bg: #22b8cf;"
			>
				BLOG
			</h1>

			<p class="blog-description">気づきや制作メモを書いています。</p>

			{
				posts.length === 0 ? (
					<p class="empty">まだ記事がありません。</p>
				) : (
					<ul class="works-grid">
						{posts.map((post, index) => {
							const themeColor = cardColors[index % cardColors.length];
							return (
								<li
									class="works-card"
									style={`--theme-color: ${themeColor};`}
								>
									{post.data.tags &&
										post.data.tags.length > 0 && (
											<ul class="card-tags">
												{post.data.tags
													.slice(0, 1)
													.map((tag: string) => (
														<li class="works-tag-item">
															{tag}
														</li>
													))}
											</ul>
										)}
									<a href={`/blog/${idToSlug(post.id)}/`}>
										<div class="card-image-wrapper">
											{post.data.heroImage ? (
												<img
													class="card-image"
													src={post.data.heroImage}
													alt={post.data.title}
												/>
											) : (
												<div class="card-image-placeholder">
													📝
												</div>
											)}
										</div>
										<div class="card-body">
											<h2 class="card-title">
												{post.data.title}
											</h2>
											<p class="card-date">
												<FormattedDate date={post.data.pubDate} />
											</p>
										</div>
									</a>
								</li>
							);
						})}
					</ul>
				)
			}
		</main>
		<Footer />
		<script>
			import { applyRandomTagColors } from "../../utils/tagColors";

			document.addEventListener("DOMContentLoaded", () =>
				applyRandomTagColors(".works-tag-item"),
			);
		</script>
	</body>
</html>
