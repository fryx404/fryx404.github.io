---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BlogPost from "../../layouts/BlogPost.astro";
import { idToSlug } from "../../utils/slug";

export async function getStaticPaths() {
	const posts = (await getCollection("blog")).sort(
		(a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf(),
	);
	return posts.map((post, index) => {
		const slug = idToSlug(post.id);
		const prevEntry = index > 0 ? posts[index - 1] : null;
		const nextEntry = index < posts.length - 1 ? posts[index + 1] : null;
		const prev = prevEntry
			? { title: prevEntry.data.title, slug: idToSlug(prevEntry.id) }
			: null;
		const next = nextEntry
			? { title: nextEntry.data.title, slug: idToSlug(nextEntry.id) }
			: null;
		return {
			params: { slug },
			props: { post, prev, next },
		};
	});
}

type Props = {
	post: CollectionEntry<"blog">;
	prev: { title: string; slug: string } | null;
	next: { title: string; slug: string } | null;
};

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
---

<BlogPost {...post.data} prev={prev} next={next}>
	<Content />
</BlogPost>
