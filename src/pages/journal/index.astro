---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import { idToSlug } from "../../utils/slug";

const posts = (await getCollection("journal")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const cardColors = [
	"#20c997",
	"#845ef7",
	"#ff922b",
	"#22b8cf",
	"#f06595",
	"#94d82d",
];

const archiveCounts = new Map<string, number>();
posts.forEach((post) => {
	const date = new Date(post.data.pubDate);
	const year = date.getFullYear().toString();
	const month = (date.getMonth() + 1).toString().padStart(2, "0");
	const key = `${year}-${month}`;
	archiveCounts.set(key, (archiveCounts.get(key) || 0) + 1);
});

const archives = Array.from(archiveCounts.entries()).sort(
	(a, b) => b[0].localeCompare(a[0]),
);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead
			title={`JOURNAL — ${SITE_TITLE}`}
			description={SITE_DESCRIPTION}
		/>
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 3em 1em;
			}
			.journal-page-title {
				--tag-bg: #20c997;
				transform: rotate(-1.5deg);
			}
			.journal-description {
				display: flex;
				justify-content: center;
				width: fit-content;
				text-align: center;
				color: var(--gray-dark);
				font-size: 1.05rem;
				font-weight: 700;
				margin: 2.5rem auto 4rem;
				padding: 0.8rem 1.8rem;
				background: #ffffff;
				border: 1px solid rgba(255, 255, 255, 0.8);
				border-radius: 999px;
				box-shadow:
					0 4px 6px -1px rgb(0 0 0 / 0.1),
					0 2px 4px -2px rgb(0 0 0 / 0.1),
					inset 0 2px 0 rgba(255, 255, 255, 0.7);
				transform: rotate(-1.5deg);
			}
			.works-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 2.5rem;
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.works-card {
				position: relative;
				border-radius: 16px;
				transition:
					box-shadow 0.2s,
					transform 0.2s;
				display: flex;
				flex-direction: column;
				overflow: visible;
			}
			.works-card:hover {
				box-shadow: 0 10px 20px -5px rgb(0 0 0 / 0.1);
				transform: translateY(-3px);
			}
			.works-card a {
				text-decoration: none;
				color: inherit;
				display: flex;
				flex-direction: column;
				height: 100%;
				border-radius: 16px;
			}
			.card-body {
				padding: 1rem;
				flex: 1;
				border-radius: 16px;
				background-color: color-mix(
					in srgb,
					var(--theme-color) 6%,
					#ffffff
				);
			}
			.card-title {
				margin: 0 0 0.4rem;
				font-size: 1.1rem;
				color: rgb(var(--black));
			}
			.card-date {
				margin: 0;
				font-size: 0.8rem;
				color: rgb(var(--gray));
			}
			@media (max-width: 720px) {
				.works-grid {
					gap: 3rem;
				}
			}
			.empty {
				color: var(--gray-dark);
				text-align: center;
				padding: 4rem 0;
			}
			.post-hidden {
				display: none;
			}
			@media (max-width: 768px) {
				.mobile-hidden {
					display: none;
				}
			}
			.load-more-wrapper {
				text-align: center;
				margin-top: 3rem;
			}
			#load-more-btn {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				padding: 0.8rem 2rem;
				font-size: 1rem;
				font-weight: 700;
				border-radius: 999px;
				border: none;
				cursor: pointer;
				background: #ffffff;
				color: var(--gray-dark);
				box-shadow:
					0 4px 6px -1px rgb(0 0 0 / 0.1),
					0 2px 4px -2px rgb(0 0 0 / 0.1),
					inset 0 2px 0 rgba(255, 255, 255, 0.7);
				transition:
					transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1),
					box-shadow 0.2s ease;
				transform: rotate(-1deg);
			}
			#load-more-btn:hover {
				transform: translateY(-3px) rotate(0deg) scale(1.04);
				box-shadow:
					0 10px 15px -3px rgb(0 0 0 / 0.12),
					0 4px 6px -4px rgb(0 0 0 / 0.1),
					inset 0 2px 0 rgba(255, 255, 255, 0.8);
			}
			.archive-widget {
				margin-top: 5rem;
				padding-top: 3rem;
				border-top: 2px dashed rgba(var(--gray-light), 0.5);
			}
			.archive-title {
				text-align: center;
				color: var(--gray-dark);
				font-size: 1.2rem;
				margin-bottom: 2rem;
			}
			.archive-list {
				display: flex;
				flex-wrap: wrap;
				gap: 1rem;
				justify-content: center;
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.archive-item a {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				padding: 0.6rem 1.2rem;
				font-size: 0.95rem;
				font-weight: 600;
				color: var(--gray-dark);
				text-decoration: none;
				background: #ffffff;
				border-radius: 999px;
				box-shadow:
					0 2px 4px -1px rgb(0 0 0 / 0.05),
					0 1px 2px -1px rgb(0 0 0 / 0.05),
					inset 0 2px 0 rgba(255, 255, 255, 0.7);
				transition:
					transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1),
					box-shadow 0.2s ease,
					color 0.2s ease;
			}
			.archive-item a:hover {
				transform: translateY(-2px) scale(1.02);
				box-shadow:
					0 6px 10px -2px rgb(0 0 0 / 0.1),
					0 2px 4px -2px rgb(0 0 0 / 0.05),
					inset 0 2px 0 rgba(255, 255, 255, 0.8);
				color: #20c997;
			}
			.archive-count {
				background: rgba(var(--gray-light), 0.5);
				padding: 0.1rem 0.5rem;
				border-radius: 999px;
				font-size: 0.8rem;
				color: var(--gray);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1
				class="section-title-tag journal-page-title"
				style="--tag-bg: #20c997;"
			>
				JOURNAL
			</h1>

			<p class="journal-description">日々の記録や思考のログです。</p>

			{
				posts.length === 0 ? (
					<p class="empty">まだ記事がありません。</p>
				) : (
					<>
						<ul class="works-grid">
							{posts.map((post, index) => {
								const themeColor =
									cardColors[index % cardColors.length];
								return (
									<li
										class={`works-card${index >= 12 ? " post-hidden" : ""}${index >= 6 && index < 12 ? " mobile-hidden" : ""}`}
										data-index={index}
										style={`--theme-color: ${themeColor};`}
									>
										<a
											href={`/journal/${idToSlug(post.id)}/`}
										>
											<div class="card-body">
												<h2 class="card-title">
													{post.data.title}
												</h2>
												<p class="card-date">
													<FormattedDate
														date={post.data.pubDate}
													/>
												</p>
											</div>
										</a>
									</li>
								);
							})}
						</ul>
						{posts.length > 6 && (
							<div class="load-more-wrapper">
								<button id="load-more-btn">
									もっと見る
								</button>
							</div>
						)}
					</>
				)
			}

			{archives.length > 0 && (
				<div class="archive-widget">
					<h2 class="archive-title">月別アーカイブ</h2>
					<ul class="archive-list">
						{archives.map(([key, count]) => {
							const [year, month] = key.split("-");
							return (
								<li class="archive-item">
									<a href={`/journal/${year}/${month}/`}>
										{year}年{parseInt(month, 10)}月
										<span class="archive-count">{count}</span>
									</a>
								</li>
							);
						})}
					</ul>
				</div>
			)}
		</main>
		<Footer />
		<script>
			const isMobile = window.innerWidth <= 768;
			const loadCount = isMobile ? 6 : 12;

			const btn = document.getElementById("load-more-btn");
			if (btn) {
				// Select elements that are hidden.
				// On mobile: .post-hidden and .mobile-hidden
				// On desktop: only .post-hidden
				const selector = isMobile ? ".post-hidden, .mobile-hidden" : ".post-hidden";
				const hiddenElements = Array.from(document.querySelectorAll(selector));

				const updateBtnText = () => {
					const remaining = hiddenElements.length;
					if (remaining === 0) {
						btn.closest(".load-more-wrapper")?.remove();
					} else {
						btn.textContent = `もっと見る (${remaining}件)`;
					}
				};
				updateBtnText();

				btn.addEventListener("click", () => {
					const next = hiddenElements.splice(0, loadCount);
					next.forEach((el) => {
						el.classList.remove("post-hidden");
						el.classList.remove("mobile-hidden");
					});
					updateBtnText();
				});
			}
		</script>
	</body>
</html>
