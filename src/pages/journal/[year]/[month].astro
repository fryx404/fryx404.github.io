---
import { getCollection } from "astro:content";
import BaseHead from "../../../components/BaseHead.astro";
import Footer from "../../../components/Footer.astro";
import FormattedDate from "../../../components/FormattedDate.astro";
import Header from "../../../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../../consts";
import { idToSlug } from "../../../utils/slug";

export async function getStaticPaths() {
	const posts = await getCollection("journal");

	// 年月の組み合わせを抽出
	const archives = new Map<string, typeof posts>();

	posts.forEach((post) => {
		const date = new Date(post.data.pubDate);
		const year = date.getFullYear().toString();
		const month = (date.getMonth() + 1).toString().padStart(2, "0");
		const key = `${year}-${month}`;

		if (!archives.has(key)) {
			archives.set(key, []);
		}
		archives.get(key)!.push(post);
	});

	return Array.from(archives.entries()).map(([key, monthPosts]) => {
		const [year, month] = key.split("-");
		// 降順ソート
		const sortedPosts = monthPosts.sort(
			(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
		);

		return {
			params: { year, month },
			props: { posts: sortedPosts, year, month },
		};
	});
}

const { posts, year, month } = Astro.props;

const cardColors = [
	"#20c997",
	"#845ef7",
	"#ff922b",
	"#22b8cf",
	"#f06595",
	"#94d82d",
];
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead
			title={`JOURNAL ${year}年${parseInt(month, 10)}月 — ${SITE_TITLE}`}
			description={`${year}年${parseInt(month, 10)}月の記事一覧です。`}
		/>
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 3em 1em;
			}
			.journal-page-title {
				--tag-bg: #20c997;
				transform: rotate(-1.5deg);
			}
			.journal-description {
				display: flex;
				justify-content: center;
				width: fit-content;
				text-align: center;
				color: var(--gray-dark);
				font-size: 1.05rem;
				font-weight: 700;
				margin: 2.5rem auto 4rem;
				padding: 0.8rem 1.8rem;
				background: #ffffff;
				border: 1px solid rgba(255, 255, 255, 0.8);
				border-radius: 999px;
				box-shadow:
					0 4px 6px -1px rgb(0 0 0 / 0.1),
					0 2px 4px -2px rgb(0 0 0 / 0.1),
					inset 0 2px 0 rgba(255, 255, 255, 0.7);
				transform: rotate(-1.5deg);
			}
			.works-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 2.5rem;
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.works-card {
				position: relative;
				border-radius: 16px;
				transition:
					box-shadow 0.2s,
					transform 0.2s;
				display: flex;
				flex-direction: column;
				overflow: visible;
			}
			.works-card:hover {
				box-shadow: 0 10px 20px -5px rgb(0 0 0 / 0.1);
				transform: translateY(-3px);
			}
			.works-card a {
				text-decoration: none;
				color: inherit;
				display: flex;
				flex-direction: column;
				height: 100%;
				border-radius: 16px;
			}
			.card-body {
				padding: 1rem;
				flex: 1;
				border-radius: 16px;
				background-color: color-mix(in srgb, var(--theme-color) 6%, #ffffff);
			}
			.card-title {
				margin: 0 0 0.4rem;
				font-size: 1.1rem;
				color: rgb(var(--black));
			}
			.card-date {
				margin: 0;
				font-size: 0.8rem;
				color: rgb(var(--gray));
			}
			@media (max-width: 720px) {
				.works-grid {
					gap: 3rem;
				}
			}
			.back-link-wrapper {
				margin-top: 4rem;
				text-align: center;
			}
			.back-link {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				gap: 0.5rem;
				font-size: 1rem;
				font-weight: 700;
				color: var(--gray-dark);
				text-decoration: none;
				padding: 0.8rem 2rem;
				background: #ffffff;
				border-radius: 999px;
				box-shadow:
					0 4px 6px -1px rgb(0 0 0 / 0.1),
					0 2px 4px -2px rgb(0 0 0 / 0.1),
					inset 0 2px 0 rgba(255, 255, 255, 0.7);
				transition:
					transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1),
					box-shadow 0.2s ease;
				transform: rotate(-1deg);
			}
			.back-link:hover {
				transform: translateY(-3px) rotate(0deg) scale(1.04);
				box-shadow:
					0 10px 15px -3px rgb(0 0 0 / 0.12),
					0 4px 6px -4px rgb(0 0 0 / 0.1),
					inset 0 2px 0 rgba(255, 255, 255, 0.8);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1
				class="section-title-tag journal-page-title"
				style="--tag-bg: #20c997;"
			>
				JOURNAL
			</h1>

			<p class="journal-description">{year}年{parseInt(month, 10)}月の記事</p>

			<ul class="works-grid">
				{posts.map((post, index) => {
					const themeColor = cardColors[index % cardColors.length];
					return (
						<li
							class="works-card"
							style={`--theme-color: ${themeColor};`}
						>
							<a href={`/journal/${idToSlug(post.id)}/`}>
								<div class="card-body">
									<h2 class="card-title">
										{post.data.title}
									</h2>
									<p class="card-date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</div>
							</a>
						</li>
					);
				})}
			</ul>

			<div class="back-link-wrapper">
				<a class="back-link" href="/journal">
					<svg
						width="20"
						height="20"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2.5"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<line x1="19" y1="12" x2="5" y2="12"></line>
						<polyline points="12 19 5 12 12 5"></polyline>
					</svg>
					JOURNAL 一覧に戻る
				</a>
			</div>
		</main>
		<Footer />
	</body>
</html>