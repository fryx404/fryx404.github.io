---
import { type CollectionEntry, getCollection, render } from "astro:content";
import JournalPost from "../../layouts/JournalPost.astro";
import { getPrevNextEntries } from "../../utils/entries";

export async function getStaticPaths() {
  const posts = (await getCollection("journal")).sort(
    (a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf(),
  );
  return getPrevNextEntries(posts);
}

type Props = {
  post: CollectionEntry<"journal">;
  prev: { title: string; slug: string } | null;
  next: { title: string; slug: string } | null;
};

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
---

<JournalPost {...post.data} prev={prev} next={next}>
  <Content />
</JournalPost>
