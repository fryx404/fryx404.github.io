---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import { idToSlug } from "../../utils/slug";

const works = (await getCollection("works")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// カードに割り当てるテーマカラー
const cardColors = [
    "#ff4b4b",
    "#22b8cf",
    "#845ef7",
    "#ff922b",
    "#94d82d",
    "#f06595",
];
---

<!doctype html>
<html lang="ja">
    <head>
        <BaseHead
            title="WORKS — 古屋 匠"
            description="古屋 匠のポートフォリオサイト"
        />
        <style>
            main {
                width: 960px;
                max-width: calc(100% - 2em);
                margin: 0 auto;
                padding: 3em 1em;
            }
            .works-page-title {
                --tag-bg: #845ef7; /* パープル系 */
                transform: rotate(1.5deg);
            }
            .works-description {
                display: flex;
                justify-content: center;
                width: fit-content;
                text-align: center;
                color: var(--gray-dark);
                font-size: 1.05rem;
                font-weight: 700;
                margin: 2.5rem auto 4rem;
                padding: 0.8rem 1.8rem;
                background: #ffffff;
                border: 1px solid rgba(255, 255, 255, 0.8);
                border-radius: 999px;
                box-shadow:
                    0 4px 6px -1px rgb(0 0 0 / 0.1),
                    0 2px 4px -2px rgb(0 0 0 / 0.1),
                    inset 0 2px 0 rgba(255, 255, 255, 0.7);
                transform: rotate(-1.5deg);
            }
            .works-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
                gap: 2.5rem;
                list-style: none;
                padding: 0;
                margin: 0;
            }
            .works-card {
                position: relative;
                border-radius: 16px;
                transition:
                    box-shadow 0.2s,
                    transform 0.2s;
                display: flex;
                flex-direction: column;
                /* ホバー時にタグがはみ出る場合は overflow: hidden だと切れてしまうため visible に */
                overflow: visible;
            }
            .works-card:hover {
                box-shadow: 0 10px 20px -5px rgb(0 0 0 / 0.1);
                transform: translateY(-3px);
            }
            .works-card a {
                text-decoration: none;
                color: inherit;
                display: flex;
                flex-direction: column;
                height: 100%;
                /* カード全体を包むaタグをborder-radiusで丸め、内部を管理するため */
                border-radius: 16px;
            }
            /* 画像コンテナにborder-radiusをつけて上の角を丸める */
            .card-image-wrapper {
                position: relative;
                width: 100%;
                aspect-ratio: 16 / 9;
            }
            .card-image {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                object-fit: cover;
                display: block;
                border-radius: 16px 16px 0 0;
            }
            .card-image-placeholder {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: linear-gradient(
                    135deg,
                    var(--gray-light),
                    var(--gray)
                );
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 2.5rem;
                border-radius: 16px 16px 0 0;
            }
            .card-body {
                padding: 1.5rem 1.2rem;
                display: flex;
                flex-direction: column;
                flex-grow: 1;
            }
            .card-title {
                margin: 0 0 0.5rem;
                font-size: 1.1rem;
                font-weight: 700;
                color: var(--black, #111827);
                line-height: 1.4;
            }
            .card-date {
                margin: 0 0 0.5rem;
                font-size: 0.85rem;
                color: var(--gray-dark);
            }
            .card-tags {
                position: absolute;
                top: 0.8rem;
                left: -0.5rem;
                display: flex;
                flex-wrap: wrap;
                justify-content: flex-start;
                gap: 0.5rem;
                list-style: none;
                padding: 0;
                margin: 0;
                z-index: 10;
            }
            .works-tag-item {
                position: relative;
                color: var(--gray-dark);
                padding: 0.25rem 0.6rem 0.25rem 1.4rem;
                display: inline-block;
                font-size: 0.8rem;
                font-weight: 700;
                filter: drop-shadow(0 3px 6px rgb(0 0 0 / 0.15));
                clip-path: polygon(10px 0, 100% 0, 100% 100%, 10px 100%, 0 50%);
                transition: transform 0.2s ease;
                transform: rotate(var(--tag-rotation, 0deg));
            }
            .works-tag-item:hover {
                transform: translateY(-2px) rotate(0deg) scale(1.05);
                z-index: 11;
            }
            .works-tag-item::before {
                content: "";
                position: absolute;
                top: 50%;
                left: 4px;
                width: 4px;
                height: 4px;
                background-color: rgb(0 0 0 / 0.15);
                border-radius: 50%;
                transform: translateY(-50%);
                box-shadow: inset 0 1px 2px rgb(0 0 0 / 0.2);
            }
            @media (max-width: 720px) {
                .works-grid {
                    gap: 3rem;
                }
            }
            .empty {
                color: var(--gray-dark);
                text-align: center;
                padding: 4rem 0;
            }
            .post-hidden {
                display: none;
            }
            .load-more-wrapper {
                text-align: center;
                margin-top: 3rem;
            }
            #load-more-btn {
                display: inline-flex;
                align-items: center;
                gap: 0.5rem;
                padding: 0.8rem 2rem;
                font-size: 1rem;
                font-weight: 700;
                border-radius: 999px;
                border: none;
                cursor: pointer;
                background: #ffffff;
                color: var(--gray-dark);
                box-shadow:
                    0 4px 6px -1px rgb(0 0 0 / 0.1),
                    0 2px 4px -2px rgb(0 0 0 / 0.1),
                    inset 0 2px 0 rgba(255, 255, 255, 0.7);
                transition:
                    transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1),
                    box-shadow 0.2s ease;
                transform: rotate(-1deg);
            }
            #load-more-btn:hover {
                transform: translateY(-3px) rotate(0deg) scale(1.04);
                box-shadow:
                    0 10px 15px -3px rgb(0 0 0 / 0.12),
                    0 4px 6px -4px rgb(0 0 0 / 0.1),
                    inset 0 2px 0 rgba(255, 255, 255, 0.8);
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <h1
                class="section-title-tag works-page-title"
                style="--tag-bg: #845ef7;"
            >
                WORKS
            </h1>

            <p class="works-description">主に自主制作作品を掲載しています。</p>

            {
                works.length === 0 ? (
                    <p class="empty">まだ作品がありません。</p>
                ) : (
                    <>
                    <ul class="works-grid">
                        {works.map((work, index) => {
                            const themeColor =
                                cardColors[index % cardColors.length];
                            return (
                                <li
                                    class={`works-card${index >= 15 ? " post-hidden" : ""}`}
                                    style={`--theme-color: ${themeColor}; background-color: color-mix(in srgb, ${themeColor} 6%, #ffffff);`}
                                >
                                    <a href={`/works/${idToSlug(work.id)}/`}>
                                        <div class="card-image-wrapper">
                                            {work.data.image ? (
                                                work.data.image.format ===
                                                "gif" ? (
                                                    <img
                                                        src={
                                                            work.data.image.src
                                                        }
                                                        alt={work.data.title}
                                                        class="card-image"
                                                        style="width: 100%; height: 100%; object-fit: cover; display: block; border-radius: 16px 16px 0 0;"
                                                    />
                                                ) : (
                                                    <Image
                                                        class="card-image"
                                                        src={work.data.image}
                                                        alt={work.data.title}
                                                        width={560}
                                                    />
                                                )
                                            ) : (
                                                <div class="card-image-placeholder">
                                                    🎨
                                                </div>
                                            )}
                                            {work.data.tags &&
                                                work.data.tags.length > 0 && (
                                                    <ul class="card-tags">
                                                        {work.data.tags
                                                            .slice(0, 1)
                                                            .map(
                                                                (
                                                                    tag: string,
                                                                ) => (
                                                                    <li class="works-tag-item">
                                                                        {tag}
                                                                    </li>
                                                                ),
                                                            )}
                                                    </ul>
                                                )}
                                        </div>
                                        <div class="card-body">
                                            <h2 class="card-title">
                                                {work.data.title}
                                            </h2>
                                            <p class="card-date">
                                                <FormattedDate
                                                    date={work.data.pubDate}
                                                />
                                            </p>
                                        </div>
                                    </a>
                                </li>
                            );
                        })}
                    </ul>
                    {works.length > 15 && (
                        <div class="load-more-wrapper">
                            <button id="load-more-btn">
                                もっと見る ({works.length - 15}件)
                            </button>
                        </div>
                    )}
                    </>
                )
            }
        </main>
        <Footer />
        <script>
            import { TAG_COLORS, applyRandomTagColors } from "../../utils/tagColors";

            document.addEventListener("DOMContentLoaded", () => {
                document.querySelectorAll<HTMLElement>(".works-card").forEach((card) => {
                    const themeColorHex = card.style.getPropertyValue("--theme-color").trim();
                    const excludeMap: Record<string, string[]> = {
                        "#ff4b4b": ["red", "pink"],
                        "#22b8cf": ["blue"],
                        "#845ef7": ["purple"],
                        "#ff922b": ["orange"],
                        "#94d82d": ["green"],
                        "#f06595": ["pink", "red"],
                    };
                    const exclude = excludeMap[themeColorHex] ?? [];
                    const available = TAG_COLORS.filter((c) => !exclude.includes(c.name));
                    applyRandomTagColors(".works-tag-item", available);
                });
            });

            const btn = document.getElementById("load-more-btn");
            if (btn) {
                btn.addEventListener("click", () => {
                    const hidden = document.querySelectorAll(".post-hidden");
                    const next15 = Array.from(hidden).slice(0, 15);
                    next15.forEach((el) => el.classList.remove("post-hidden"));
                    const remaining = document.querySelectorAll(".post-hidden").length;
                    if (remaining === 0) {
                        btn.closest(".load-more-wrapper")?.remove();
                    } else {
                        btn.textContent = `もっと見る (${remaining}件)`;
                    }
                });
            }
        </script>
    </body>
</html>
