---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import WorksShowcase from "../../components/WorksShowcase.astro";

const works = (await getCollection("works")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// カードに割り当てるテーマカラー
const cardColors = [
    "#ff4b4b",
    "#22b8cf",
    "#845ef7",
    "#ff922b",
    "#94d82d",
    "#f06595",
];
---

<!doctype html>
<html lang="ja">
    <head>
        <BaseHead
            title="WORKS — 古屋 匠"
            description="古屋 匠のポートフォリオサイト"
        />
        <style>
            main {
                width: 960px;
                max-width: calc(100% - 2em);
                margin: 0 auto;
                padding: 3em 1em;
            }
            .works-page-title {
                --tag-bg: #845ef7; /* パープル系 */
                transform: rotate(1.5deg);
            }
            .works-description {
                display: flex;
                justify-content: center;
                width: fit-content;
                text-align: center;
                color: var(--gray-dark);
                font-size: 1.05rem;
                font-weight: 700;
                margin: 2.5rem auto 4rem;
                padding: 0.8rem 1.8rem;
                background: #ffffff;
                border: 1px solid rgba(255, 255, 255, 0.8);
                border-radius: 999px;
                box-shadow:
                    0 4px 6px -1px rgb(0 0 0 / 0.1),
                    0 2px 4px -2px rgb(0 0 0 / 0.1),
                    inset 0 2px 0 rgba(255, 255, 255, 0.7);
                transform: rotate(-1.5deg);
            }

            /* ===== もっと見るボタン ===== */
            .load-more-wrapper {
                text-align: center;
                margin-top: 3rem;
            }
            #load-more-btn {
                display: inline-flex;
                align-items: center;
                gap: 0.5rem;
                padding: 0.8rem 2rem;
                font-size: 1rem;
                font-weight: 700;
                border-radius: 999px;
                border: none;
                cursor: pointer;
                background: #ffffff;
                color: var(--gray-dark);
                box-shadow:
                    0 4px 6px -1px rgb(0 0 0 / 0.1),
                    0 2px 4px -2px rgb(0 0 0 / 0.1),
                    inset 0 2px 0 rgba(255, 255, 255, 0.7);
                transition:
                    transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1),
                    box-shadow 0.2s ease;
                transform: rotate(-1deg);
            }
            #load-more-btn:hover {
                transform: translateY(-3px) rotate(0deg) scale(1.04);
                box-shadow:
                    0 10px 15px -3px rgb(0 0 0 / 0.12),
                    0 4px 6px -4px rgb(0 0 0 / 0.1),
                    inset 0 2px 0 rgba(255, 255, 255, 0.8);
            }

            .empty {
                color: var(--gray-dark);
                text-align: center;
                padding: 4rem 0;
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <h1
                class="section-title-tag works-page-title"
                style="--tag-bg: #845ef7;"
            >
                WORKS
            </h1>

            <p class="works-description">自主制作作品を掲載しています。</p>

            {
                works.length === 0 ? (
                    <p class="empty">まだ作品がありません。</p>
                ) : (
                    <>
                    {works.map((work, index) => {
                        const themeColor =
                            cardColors[index % cardColors.length];
                        return (
                            <WorksShowcase work={work} index={index} themeColor={themeColor} />
                        );
                    })}
                    {works.length > 15 && (
                        <div class="load-more-wrapper">
                            <button id="load-more-btn">
                                もっと見る ({works.length - 15}件)
                            </button>
                        </div>
                    )}
                    </>
                )
            }
        </main>
        <Footer />
        <script>
            import { TAG_COLORS, applyRandomTagColors } from "../../utils/tagColors";

            document.addEventListener("DOMContentLoaded", () => {
                // --- タグカラー適用 ---
                const excludeMap: Record<string, string[]> = {
                    "#ff4b4b": ["red", "pink"],
                    "#22b8cf": ["blue"],
                    "#845ef7": ["purple"],
                    "#ff922b": ["orange"],
                    "#94d82d": ["green"],
                    "#f06595": ["pink", "red"],
                };

                document.querySelectorAll<HTMLElement>(".showcase-section").forEach((section) => {
                    const themeColorHex = section.dataset.themeColor || "";
                    const exclude = excludeMap[themeColorHex] ?? [];
                    const available = TAG_COLORS.filter((c) => !exclude.includes(c.name));
                    applyRandomTagColors(".showcase-tag-item", available, section);
                });

                // --- Intersection Observer: スクロールフェードイン ---
                const observer = new IntersectionObserver(
                    (entries) => {
                        entries.forEach((entry) => {
                            if (entry.isIntersecting) {
                                entry.target.classList.add("is-visible");
                                observer.unobserve(entry.target);
                            }
                        });
                    },
                    { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
                );

                document.querySelectorAll(".showcase-section").forEach((section) => {
                    observer.observe(section);
                });

                // --- もっと見る ---
                const btn = document.getElementById("load-more-btn");
                if (btn) {
                    const hiddenElements = Array.from(
                        document.querySelectorAll(".post-hidden"),
                    );
                    btn.addEventListener("click", () => {
                        const next15 = hiddenElements.splice(0, 15);
                        next15.forEach((el) => {
                            el.classList.remove("post-hidden");
                            // 新しく表示されたセクションもobserveする
                            observer.observe(el);
                        });
                        const remaining = hiddenElements.length;
                        if (remaining === 0) {
                            btn.closest(".load-more-wrapper")?.remove();
                        } else {
                            btn.textContent = `もっと見る (${remaining}件)`;
                        }
                    });
                }
            });
        </script>
    </body>
</html>
