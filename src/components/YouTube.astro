---
interface Props {
	url: string;
}

const { url } = Astro.props;

// 通常URL・短縮URL・embed URLからIDを抽出
const videoId =
	url.match(/[?&]v=([^&#]+)/)?.[1] ??
	url.match(/youtu\.be\/([^?&#]+)/)?.[1] ??
	url.match(/embed\/([^?&#]+)/)?.[1] ??
	'';
---

{videoId && (
	<div class="yt-wrapper">
		<iframe
			src={`https://www.youtube-nocookie.com/embed/${videoId}`}
			title="YouTube video"
			allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
			allowfullscreen
			loading="lazy"
		></iframe>
	</div>
)}

<style>
	.yt-wrapper {
		position: relative;
		width: 100%;
		aspect-ratio: 16 / 9;
		margin: 1.5rem 0;
		border-radius: 8px;
		overflow: hidden;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
	}
	iframe {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		border: none;
	}
</style>
