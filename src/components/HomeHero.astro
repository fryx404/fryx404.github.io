---
---
<section class="hero">
  <div class="avatar">
    <img src="/icons/Profile.png" alt="Profile" />
  </div>
  <h1 class="hero-name">古屋 匠</h1>
  <div class="hero-badges">
    <span class="feature-tag">CG Designer</span>
    <span class="feature-tag">Rigger</span>
    <span class="feature-tag">Creator</span>
  </div>
</section>

<style>
  /* --- ヒーローセクション（プロフィール） --- */
  .hero {
    max-width: 720px;
    margin: 0 auto 0rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .avatar {
    margin-bottom: 1.5rem;
    display: flex;
    justify-content: center;
  }
  .avatar img {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    object-fit: cover;
    /* ステッカー風の太枠と影 */
    border: 6px solid #ffffff;
    box-shadow:
      0 12px 20px -8px rgb(0 0 0 / 0.15),
      0 4px 6px -2px rgb(0 0 0 / 0.1);
  }
  .hero-name {
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--black);
    margin: 0 0 1.2rem 0;
    position: relative;
    display: inline-block;
    /* マーカー風の黄色いアンダーライン */
    background: linear-gradient(
      transparent 65%,
      rgba(255, 213, 79, 0.8) 65%
    );
    padding: 0 0.5rem;
  }
  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
  }

  /* feature-tag は各所で使われるため、ここでも定義 (global.cssで定義されていないため) */
  .feature-tag {
    position: relative;
    color: var(--gray-dark);
    padding: 0.35rem 0.8rem 0.35rem 1.6rem;
    border-radius: 0 4px 4px 0;
    font-size: 1rem;
    font-weight: 700;
    filter: drop-shadow(0 3px 6px rgb(0 0 0 / 0.15));
    clip-path: polygon(12px 0, 100% 0, 100% 100%, 12px 100%, 0 50%);
    transition: transform 0.2s ease;
    transform: rotate(var(--tag-rotation, 0deg));
  }
  .feature-tag:hover {
    transform: translateY(-2px) rotate(0deg) scale(1.05);
    z-index: 11;
  }
  .feature-tag::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 6px;
    width: 5px;
    height: 5px;
    background-color: rgb(0 0 0 / 0.15);
    border-radius: 50%;
    transform: translateY(-50%);
    box-shadow: inset 0 1px 2px rgb(0 0 0 / 0.2);
  }
</style>
