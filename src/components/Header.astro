---
import HeaderLink from "./HeaderLink.astro";
---

<header>
	<nav>
		<button class="hamburger" id="hamburger-btn" aria-label="メニューを開く" aria-expanded="false">
			<span class="hamburger-line"></span>
			<span class="hamburger-line"></span>
			<span class="hamburger-line"></span>
		</button>
		<div class="internal-links" id="nav-links">
			<HeaderLink href="/">HOME</HeaderLink>
			<HeaderLink href="/works">WORKS</HeaderLink>
			<HeaderLink href="/blog">BLOG</HeaderLink>
			<HeaderLink href="/journal">JOURNAL</HeaderLink>
			<HeaderLink href="https://note.com/fryx404" target="_blank" rel="noopener noreferrer">
				<span style="font-weight: 550;">note</span>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					width="14"
					height="14"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="3"
					stroke-linecap="round"
					stroke-linejoin="round"
					style="margin-bottom: 2px;"
				>
					<path
						d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"
					></path>
					<polyline points="15 3 21 3 21 9"></polyline>
					<line x1="10" y1="14" x2="21" y2="3"></line>
				</svg>
			</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		margin: 0;
		padding: 1rem 1em;
		background: color-mix(in srgb, var(--gray-light) 90%, transparent);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid
			color-mix(in srgb, var(--gray) 30%, transparent);
		box-shadow: 0 1px 5px color-mix(in srgb, var(--gray) 20%, transparent);
	}
	.internal-links {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
		justify-content: center;
		max-width: 720px;
		margin: 0 auto;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: center;
	}
	nav a {
		display: flex;
		align-items: center;
		gap: 0.3rem;
		padding: 0.6rem 1.2rem;
		color: var(--gray-dark);
		border-radius: 9999px;
		font-size: 1rem;
		font-weight: 550;
		text-decoration: none;
		transition: all 0.2s ease;
	}
	nav a:hover {
		background-color: color-mix(in srgb, var(--gray) 20%, transparent);
		color: var(--gray-dark);
	}
	nav a.active {
		background-color: var(--accent);
		color: var(--gray-light);
		box-shadow: 0 2px 2px color-mix(in srgb, var(--accent) 40%, transparent);
	}

	/* ハンバーガーボタン（デスクトップでは非表示） */
	.hamburger {
		display: none;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 6px;
		border-radius: 8px;
		transition: background-color 0.2s ease;
	}
	.hamburger:hover {
		background-color: color-mix(in srgb, var(--gray) 20%, transparent);
	}
	.hamburger-line {
		display: block;
		width: 24px;
		height: 2.5px;
		background-color: var(--gray-dark);
		border-radius: 2px;
		transition: all 0.3s ease;
	}
	/* ×アイコンへの変形 */
	.hamburger.open .hamburger-line:nth-child(1) {
		transform: translateY(7.5px) rotate(45deg);
	}
	.hamburger.open .hamburger-line:nth-child(2) {
		opacity: 0;
	}
	.hamburger.open .hamburger-line:nth-child(3) {
		transform: translateY(-7.5px) rotate(-45deg);
	}

	/* モバイル表示 */
	@media (max-width: 768px) {
		nav {
			display: grid;
			grid-template-columns: 1fr auto 1fr;
			align-items: center;
		}
		.hamburger {
			display: flex;
			grid-column: 3;
			justify-self: flex-end;
			margin: 0;
		}
		.internal-links {
			display: flex;
			flex-direction: row;
			gap: 0.25rem;
			padding-top: 0;
			width: auto;
			margin: 0;
			grid-column: 2;
			grid-row: 1;
		}
		.internal-links > a:not([href="/"], [href="/works"], [href="/blog"]) {
			display: none;
		}
		.internal-links.open {
			flex-direction: column;
			align-items: flex-end;
			width: 100%;
			padding-top: 0.75rem;
			grid-column: 1 / -1;
			grid-row: 2;
		}
		.internal-links.open > a {
			display: flex;
		}
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const btn = document.getElementById('hamburger-btn');
		const nav = document.getElementById('nav-links');
		if (!btn || !nav) return;

		btn.addEventListener('click', () => {
			const isOpen = nav.classList.toggle('open');
			btn.classList.toggle('open', isOpen);
			btn.setAttribute('aria-expanded', String(isOpen));
		});

		// リンクタップで閉じる (イベントデリゲーション)
		nav.addEventListener('click', (e) => {
			const link = (e.target as Element).closest('a');
			if (link && nav.contains(link)) {
				nav.classList.remove('open');
				btn.classList.remove('open');
				btn.setAttribute('aria-expanded', 'false');
			}
		});

		// メニュー外タップで閉じる
		document.addEventListener('click', (e) => {
			if (!btn.contains(e.target as Node) && !nav.contains(e.target as Node)) {
				nav.classList.remove('open');
				btn.classList.remove('open');
				btn.setAttribute('aria-expanded', 'false');
			}
		});
	});
</script>
