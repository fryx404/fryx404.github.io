---
import HeaderLink from "./HeaderLink.astro";
---

<header>
	<nav>
		<div class="internal-links">
			<HeaderLink href="/">HOME</HeaderLink>
			<HeaderLink href="/works">WORKS</HeaderLink>
			<HeaderLink href="/blog">BLOG</HeaderLink>
			<HeaderLink href="https://note.com/fryx404" target="_blank">
				<span style="font-weight: 400;">note</span>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					width="14"
					height="14"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="3"
					stroke-linecap="round"
					stroke-linejoin="round"
					style="margin-bottom: 2px;"
				>
					<path
						d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"
					></path>
					<polyline points="15 3 21 3 21 9"></polyline>
					<line x1="10" y1="14" x2="21" y2="3"></line>
				</svg>
			</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		margin: 0;
		padding: 1rem 1em;
		background: color-mix(in srgb, var(--gray-light) 90%, transparent);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid
			color-mix(in srgb, var(--gray) 30%, transparent);
		box-shadow: 0 1px 5px color-mix(in srgb, var(--gray) 20%, transparent);
	}
	.internal-links {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
		justify-content: center;
		max-width: 720px;
		margin: 0 auto;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: center;
	}
	nav a {
		display: flex;
		align-items: center;
		gap: 0.3rem;
		padding: 0.6rem 1.2rem;
		color: var(--gray-dark);
		border-radius: 9999px;
		font-size: 1rem;
		font-weight: 550;
		text-decoration: none;
		transition: all 0.2s ease;
	}
	nav a:hover {
		background-color: color-mix(in srgb, var(--gray) 20%, transparent);
		color: var(--gray-dark);
	}
	nav a.active {
		background-color: var(--accent);
		color: var(--gray-light);
		box-shadow: 0 2px 2px color-mix(in srgb, var(--accent) 40%, transparent);
	}
</style>
