---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
    work: CollectionEntry<"works">;
    index: number;
    themeColor: string;
}

const { work, index, themeColor } = Astro.props;
---

<section
    class={`showcase-section${index >= 15 ? " post-hidden" : ""}`}
    style={`background-color: color-mix(in srgb, ${themeColor} 6%, #ffffff);`}
    data-theme-color={themeColor}
>
    <div class="showcase-inner">
        {/* テキストエリア */}
        <div class="showcase-text-area">
            {work.data.tags && work.data.tags.length > 0 && (
                <ul class="showcase-tags">
                    {work.data.tags.map((tag: string) => (
                        <li class="showcase-tag-item">{tag}</li>
                    ))}
                </ul>
            )}

            <h2 class="showcase-title">{work.data.title}</h2>

            {work.data.description && (
                <p class="showcase-description">{work.data.description}</p>
            )}

            {work.data.features && work.data.features.length > 0 && (
                <ul
                    class="showcase-features"
                    style={`--feature-check-color: ${themeColor};`}
                >
                    {work.data.features.map((feature: string) => (
                        <li>{feature}</li>
                    ))}
                </ul>
            )}

            {work.data.url && (
                <a
                    class="showcase-cta"
                    href={work.data.url}
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    View More →
                </a>
            )}
        </div>

        {/* 画像エリア */}
        <div class="showcase-image-area">
            <div class="showcase-image-wrapper">
                {work.data.image ? (
                    work.data.image.format === "gif" ? (
                        <img
                            src={work.data.image.src}
                            alt={work.data.title}
                            class="showcase-image"
                        />
                    ) : (
                        <Image
                            class="showcase-image"
                            src={work.data.image}
                            alt={work.data.title}
                            width={720}
                        />
                    )
                ) : (
                    <div class="showcase-image-placeholder">🎨</div>
                )}
            </div>
        </div>
    </div>
</section>

<style>
    /* ===== ショーケースセクション ===== */
    .showcase-section {
        border-radius: 20px;
        padding: 3rem 2.5rem;
        margin-bottom: 3rem;
        /* フェードインアニメーション用 */
        opacity: 0;
        transform: translateY(40px);
        transition:
            opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
            transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .showcase-section.is-visible {
        opacity: 1;
        transform: translateY(0);
    }

    .showcase-inner {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        align-items: center;
    }

    /* 偶数番目: 画像が左 → order で入れ替え */
    .showcase-section:nth-of-type(even) .showcase-image-area {
        order: -1;
    }

    /* --- 画像エリア --- */
    .showcase-image-area {
        position: relative;
        width: 100%;
        border-radius: 14px;
        overflow: hidden;
    }
    .showcase-image-wrapper {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 10;
        border-radius: 14px;
        overflow: hidden;
        box-shadow:
            0 8px 30px -6px rgb(0 0 0 / 0.12),
            0 4px 12px -4px rgb(0 0 0 / 0.08);
    }
    .showcase-image {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        border-radius: 14px;
        transition: transform 0.4s ease;
    }
    .showcase-section:hover .showcase-image {
        transform: scale(1.03);
    }
    .showcase-image-placeholder {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, var(--gray-light), var(--gray));
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        border-radius: 14px;
    }

    /* --- テキストエリア --- */
    .showcase-text-area {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    /* タグ群（画像上ではなくテキスト側に配置） */
    .showcase-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .showcase-tag-item {
        position: relative;
        color: var(--gray-dark);
        padding: 0.25rem 0.6rem 0.25rem 1.4rem;
        display: inline-block;
        font-size: 0.8rem;
        font-weight: 700;
        filter: drop-shadow(0 3px 6px rgb(0 0 0 / 0.15));
        clip-path: polygon(10px 0, 100% 0, 100% 100%, 10px 100%, 0 50%);
        transition: transform 0.2s ease;
        transform: rotate(var(--tag-rotation, 0deg));
    }
    .showcase-tag-item:hover {
        transform: translateY(-2px) rotate(0deg) scale(1.05);
        z-index: 11;
    }
    .showcase-tag-item::before {
        content: "";
        position: absolute;
        top: 50%;
        left: 4px;
        width: 4px;
        height: 4px;
        background-color: rgb(0 0 0 / 0.15);
        border-radius: 50%;
        transform: translateY(-50%);
        box-shadow: inset 0 1px 2px rgb(0 0 0 / 0.2);
    }

    .showcase-title {
        margin: 0;
        font-size: 1.6rem;
        font-weight: 800;
        color: var(--black, #111827);
        line-height: 1.3;
    }

    .showcase-date {
        font-size: 0.85rem;
        color: var(--gray-dark);
        margin: 0;
    }

    .showcase-description {
        font-size: 0.95rem;
        color: var(--gray-dark);
        line-height: 1.7;
        margin: 0;
    }

    /* --- 特徴リスト (features) --- */
    .showcase-features {
        list-style: none;
        padding: 0;
        margin: 0.5rem 0 0;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }
    .showcase-features li {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-size: 0.92rem;
        font-weight: 600;
        color: var(--gray-dark);
    }
    .showcase-features li::before {
        content: "✓";
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 20px;
        height: 20px;
        font-size: 0.75rem;
        font-weight: 800;
        color: #fff;
        background: var(--feature-check-color, var(--gray));
        border-radius: 50%;
        flex-shrink: 0;
    }

    /* --- CTAボタン（pill型＋斜め配置＋ホバーで水平化） --- */
    .showcase-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        width: fit-content;
        padding: 0.7rem 1.6rem;
        font-size: 0.95rem;
        font-weight: 700;
        border-radius: 999px;
        border: none;
        cursor: pointer;
        background: #ffffff;
        color: var(--gray-dark);
        text-decoration: none;
        box-shadow:
            0 4px 6px -1px rgb(0 0 0 / 0.1),
            0 2px 4px -2px rgb(0 0 0 / 0.1),
            inset 0 2px 0 rgba(255, 255, 255, 0.7);
        transition:
            transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1),
            box-shadow 0.2s ease;
        transform: rotate(-1.5deg);
        margin-top: 0.5rem;
    }
    .showcase-cta:hover {
        transform: translateY(-3px) rotate(0deg) scale(1.04);
        box-shadow:
            0 10px 15px -3px rgb(0 0 0 / 0.12),
            0 4px 6px -4px rgb(0 0 0 / 0.1),
            inset 0 2px 0 rgba(255, 255, 255, 0.8);
        color: var(--black);
    }

    /* ===== もっと見るボタン (indexに移行しますが初期ロード用) ===== */
    .post-hidden {
        display: none;
    }

    /* ===== レスポンシブ ===== */
    @media (max-width: 768px) {
        .showcase-section {
            padding: 2rem 1.5rem;
            margin-bottom: 2rem;
        }
        .showcase-inner {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }
        /* モバイルでは常に画像が上 */
        .showcase-section:nth-of-type(even) .showcase-image-area {
            order: -1;
        }
        .showcase-image-area {
            order: -1;
        }
        .showcase-title {
            font-size: 1.3rem;
        }
    }
</style>
